{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "private": true,
  "description": "An impressive Pomodoro timer application to enhance productivity.",
  "keywords": ["pomodoro", "timer", "productivity", "focus", "time-management"],
  "homepage": "https://pomodoro.kajkowalski.nl",
  "repository": {
    "type": "git",
    "url": "https://github.com/kjanat/pomodoro-timer.git"
  },
  "license": "MIT",
  "author": "Kaj Kowalski",
  "type": "module",
  "main": "src/js/app.ts",
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot src/index.html",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome check --fix",
    "preview": "run-s build serve",
    "serve": "bunx serve dist/",
    "start": "bun run --hot src/js/app.ts",
    "test": "vitest run",
    "test:all": "run-s test test:e2e",
    "test:bun": "bun test",
    "test:bun:log": "bun test |& tee test.log",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "lucide": "^0.553.0"
  },
  "devDependencies": {
    "@3c1u/bun-run-all": "^0.1.2",
    "@biomejs/biome": "2.3.4",
    "@happy-dom/global-registrator": "^20.0.10",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.2",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "jsdom": "^27.1.0",
    "playwright": "^1.56.1",
    "prettier": "~3.6.2",
    "prettier-config-standard": "^7.0.0",
    "vitest": "~4.0.8"
  },
  "peerDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20251108.1",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.1"
}
