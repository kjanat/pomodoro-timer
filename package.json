{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "An impressive Pomodoro timer application to enhance productivity.",
  "keywords": [
    "pomodoro",
    "timer",
    "productivity",
    "focus",
    "time-management"
  ],
  "homepage": "https://pomodoro.kajkowalski.nl",
  "repository": {
    "type": "git",
    "url": "https://github.com/kjanat/pomodoro-timer.git"
  },
  "license": "MIT",
  "author": "Kaj Kowalski",
  "type": "module",
  "imports": {
    "#js/*": "./src/js/*.ts",
    "#tests/*": "./tests/*.ts"
  },
  "main": "src/js/app.ts",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.html --outdir=dist --minify && bun build ./src/sw.ts --outdir=dist --target=browser --minify",
    "dev": "bun ./src/index.html --port 3000",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\" \"scripts/**/*.ts\" \"*.{ts,json,md}\" --ignore-path .gitignore",
    "lint": "tsc --noEmit",
    "lint:fix": "tsc --noEmit",
    "preview": "bun run scripts/serve-dist.ts",
    "start": "bun ./src/index.html --port 3000",
    "test": "bun test",
    "test:all": "bun run test && bun run test:e2e",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "bun test --watch"
  },
  "prettier": "prettier-config-standard",
  "dependencies": {
    "lucide": "^1.21.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "playwright": "^1.61.1",
    "prettier": "~3.9.1",
    "prettier-config-standard": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
